OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
XAI_API_KEY=your_xai_api_key_here
ZHIPU_API_KEY=your_zhipu_api_key_here


# LLM Provider for text formatting: 'anthropic' (Claude) or 'openai' (GPT)
# Claude is recommended for long transcriptions due to larger context window
LLM_PROVIDER=anthropic

# MySQL Configuration
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=goswami_whisper
MYSQL_USER=goswami
MYSQL_PASSWORD=goswamipassword
MYSQL_HOST=localhost
MYSQL_PORT=3306

# Flask Configuration
FLASK_SECRET_KEY=your-secret-key-change-in-production
FLASK_DEBUG=True

# Whisper Configuration (tiny, base, small, medium, large)
WHISPER_MODEL=medium

# Goswami external PostgreSQL database (for upload by ID)
GOSWAMI_DB_NAME=goswami.ru
GOSWAMI_DB_USER=postgres
GOSWAMI_DB_PASSWORD=postgres
GOSWAMI_DB_HOST=localhost
GOSWAMI_DB_PORT=5431

# Media files root prefix (path to audio files on disk)
MEDIA_ROOT_PREFIX=~/hdd/media/bvgm.su

# LM Studio Configuration (port 1234)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
# Timeout in seconds for LM Studio requests (default: 3600 = 1 hour)
# LM Studio can be very slow on large texts, increase if needed
LMSTUDIO_TIMEOUT=4600

# Ollama Configuration (default port 11434)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_TIMEOUT=3600

# vLLM Configuration (default port 8000)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_TIMEOUT=3600

# Llama.cpp / llama-server Configuration (default port 12345)
LLAMA_BASE_URL=http://localhost:12345/v1
LLAMA_TIMEOUT=3600

